{
  "manifest_version": 3,
  "name": "Network Exporter",
  "description": "Select DevTools network requests and copy focused JSON or Markdown exports.",
  "version": "0.1.0",
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "clipboardWrite"
  ]
}
